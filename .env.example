# ═══════════════════════════════════════════
#  WA-AKG Business — Environment Config
# ═══════════════════════════════════════════
# cp .env.example .env  →  edit  →  docker compose up --build
#
# Architecture:
#   nginx (4040 exposed) → frontend:4041 + backend:4000 (internal)

PORT=4040
APP_PORT=4000
APP_SECRET=change-me-to-random-32-bytes
# Optional: separate secret for refresh tokens (falls back to APP_SECRET)
REFRESH_SECRET=change-me-to-random-32-bytes-too
NODE_ENV=production
FRONTEND_URL=http://localhost:4040

# AI Provider (OpenAI-compatible)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key
AI_MODEL=gpt-4o
AI_MAX_TOKENS=1024

# Database (SQLite via libsql)
DB_PATH=file:./data/wa_akg.db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXT_PORT=6380

# Web Push (VAPID) — generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Frontend
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_VAPID_KEY=

# WhatsApp Gateway
WA_SESSION_PATH=./sessions

# Pagination
MESSAGES_PAGE_SIZE=30
CONVERSATIONS_PAGE_SIZE=20
MESSAGES_SOFT_CAP=5000
CONTEXT_EXPIRY_DAYS=90

# Notifications
NOTIF_QUEUE_THRESHOLD=5
NOTIF_DEBOUNCE_SECONDS=30

